# Environment variables for the Ethical Hacking AI Agent

# Paths
AGENT_CONFIG_PATH=./configs/agent_config.yaml
LOG_DIR=./data/logs
SCAN_OUTPUT_DIR=./data/scans

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json   # or 'text'

# Database Configuration
# Set to postgresql+asyncpg for production, or sqlite+aiosqlite for local dev
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/ai_hacker_db
# DATABASE_URL=sqlite+aiosqlite:///./data/results.db

# AI Integration (for real zero-day remediation and analysis)
OPENAI_API_KEY=your_openai_api_key_here

# CVE database update
NVD_API_KEY=your_nvd_api_key_here   # Optional, for faster updates
VULN_DB_UPDATE_INTERVAL=86400        # Seconds (24 hours)

# Dynamic testing
DYNAMIC_SERVER_HOST=127.0.0.1
DYNAMIC_SERVER_PORT=8080
DYNAMIC_SERVER_TYPE=auto   # python, php, node, or auto
ZAP_PATH=/usr/local/bin/zap.sh   # Path to OWASP ZAP (if used)

# Web UI (if enabled)
FLASK_SECRET_KEY=change_this_in_production
FLASK_DEBUG=0
FLASK_HOST=0.0.0.0
FLASK_PORT=5000